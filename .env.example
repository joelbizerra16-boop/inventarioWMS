# =============================================================================
# Django — obrigatórias em produção (Render)
# =============================================================================
SECRET_KEY=change-me-use-50-plus-random-characters-in-production
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# =============================================================================
# Banco — Supabase PostgreSQL
# =============================================================================
# Recomendado: URI do pooler (Transaction mode, porta 6543) no Render.
# Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Use True quando DATABASE_URL apontar para PgBouncer/Supabase pooler (porta 6543).
DB_USE_PGBOUNCER=True

# Persistência de conexão (segundos). Use 0 com PgBouncer.
DB_CONN_MAX_AGE=0

# Alternativa sem DATABASE_URL (não recomendado em produção):
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=db.[PROJECT-REF].supabase.co
# DB_PORT=5432
# DB_SSLMODE=require

# =============================================================================
# Supabase — opcional (APIs / integrações futuras; não usado pelo ORM Django)
# =============================================================================
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# =============================================================================
# Segurança HTTPS (Render)
# =============================================================================
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# =============================================================================
# Aplicação
# =============================================================================
RELATORIO_CICLICO_EMPRESA=Brida Logística
RELATORIO_CICLICO_LOGO=
LOG_LEVEL=INFO

# Limite de upload (bytes) — importações Excel
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# Timeout de lock de inventário multiusuário (segundos) — default 900 (15 min)
INVENTARIO_LOCK_TIMEOUT_SECONDS=900

# =============================================================================
# Desenvolvimento local (exemplo)
# =============================================================================
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=sqlite:///db.sqlite3
# DB_USE_PGBOUNCER=False
# SECURE_SSL_REDIRECT=False
